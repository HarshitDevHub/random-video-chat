{
  "name": "random-video-chat",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server/server\" \"npm run dev --prefix client\"",
    "dev:server": "npm run dev --prefix server/server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "npm run start --prefix server/server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
